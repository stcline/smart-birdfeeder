# Smart Birdfeeder — Environment Configuration
# Copy this file to config/.env and fill in your values
# Load in scripts with: from dotenv import load_dotenv; load_dotenv("config/.env")

# ─── iNaturalist ──────────────────────────────────────────────────────────────
# JWT token from https://www.inaturalist.org/users/api_token
# Expires every 24 hours — auto-refreshed by scripts/refresh_inat_token.py cron job
INAT_API_TOKEN=your_jwt_token_here

# OAuth app credentials — required for automated token refresh
# Register your app at https://www.inaturalist.org/oauth/applications/new
# Set Confidential=true, Redirect URI=https://localhost
INAT_USERNAME=your_inaturalist_username
INAT_PASSWORD=your_inaturalist_password
INAT_APP_ID=your_oauth_app_id
INAT_APP_SECRET=your_oauth_app_secret

# ─── BirdWeather / Haikubox ───────────────────────────────────────────────────
# Your BirdWeather station ID (found in BirdWeather app settings)
BIRDWEATHER_STATION_ID=your_station_id_here
# BirdWeather API token
BIRDWEATHER_TOKEN=your_birdweather_token_here

# ─── Database ─────────────────────────────────────────────────────────────────
# Local path while NAS is unavailable — update to NFS mount path later
DB_PATH=/home/steve/birdfeeder/birdfeeder.db

# ─── Storage ──────────────────────────────────────────────────────────────────
# Local SD card path (active until NAS is set up)
SAVE_DIR=/home/steve/birdfeeder/captures
# NAS mount path (set when NAS is available — leave blank until then)
NAS_MOUNT_PATH=
